{
  "name": "@messagebird/sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for the Bird API.",
  "license": "MIT",
  "author": "Bird",
  "homepage": "https://github.com/messagebird/bird-sdk-node#readme",
  "bugs": {
    "url": "https://github.com/messagebird/bird-sdk-node/issues"
  },
  "keywords": [
    "bird",
    "email",
    "webhooks",
    "sdk",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/messagebird/bird-sdk-node.git"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module-sync": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit && tsc --noEmit -p examples/tsconfig.json",
    "generate": "openapi-ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "standardwebhooks": "^1.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
